	"IsBetaVersion": false,
	"Installed": false,
	"Modules": [
		{
			"Name": "AFLNetTypes",
			"Type": "Runtime",
			"LoadingPhase": "Default"
		}
	],
	"Plugins": [
		{
			"Name": "GameplayAbilities",
			"Enabled": true
		}
	]
