# === Visual Studio / Rider ===
.vs/
.idea/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# === Unreal Engine — regenerable, NEVER commit ===
Binaries/
DerivedDataCache/
Intermediate/
Saved/
*.target
*.modules

# Plugin-local regenerables
Plugins/**/Binaries/
Plugins/**/Intermediate/

# === IDE & editor caches ===
.vscode/
*.swp
*~

# === OS junk ===
Thumbs.db
.DS_Store
desktop.ini

# === Build artifacts ===
*.pdb
*.exp
*.lib
*.dll
*.exe

# === Temp / scratch ===
*.tmp
*.bak
*.log

# Visual Studio per-user config
.vsconfig

# === Claude Code local project state ===
.claude/

# === Plugin installer archives at repo root (use Fab or download fresh) ===
/AgentIntegrationKit-*.zip

# === Per-developer secrets — NEVER commit ===
# AIK / NeoStack API keys and any developer-specific overrides.
Config/User*.ini
*.env
*.secret
secrets/
**/credentials.json
# Defensive: catch any *.ini that contains "ApiKey" by filename convention
**/ApiKeys.ini
**/*_keys.ini


# afl_yolo
Tools/AFL_Yolo/.state/
Tools/AFL_Yolo/config.toml

# Python bytecode cache
**/__pycache__/
*.pyc

# Local credential backup
Tools/AFL_Yolo/config.toml.backup

# === Session scratch / local-only working dirs (keep on disk, don't track) ===
# Unzipped marketplace pack source (the zip is the SSOT; this is an extract-on-demand working copy).
Tools/_laser_src/
# Skill BUNDLES dropped into Tools/skills as raw .skill ZIPs (the visual-spec source, e.g.
# expert-game-designer.skill). Installed skills live in Tools/skills/<name>/SKILL.md folders; the
# raw bundles are local references, not tracked.
Tools/skills/*.skill
# Temporary diagnostic content (B_*_AssignCharacterPart probes etc) — session scratch, never shipped.
Content/_TmpDiag/
# Agent scratch markers
Tools/_commit_msg*.txt
Tools/_commit_canary.txt
Tools/_gate2_live.png
