{
  "_comment": "AAA conformance budgets per master doc Sec. 16.2 (lines 2105-2114). Edit here; UE-side DT_AFL_MeshBudgets.uasset is a planned follow-up wrapper.",
  "version": 1,
  "classes": {
    "hero_char": {
      "lod0_tris": 80000,
      "lod3_tris": 8000,
      "tex_max": 4096,
      "mat_slots": 8
    },
    "heavy_weapon": {
      "lod0_tris": 25000,
      "lod3_tris": 3000,
      "tex_max": 2048,
      "mat_slots": 4
    },
    "env_prop": {
      "lod0_tris": 15000,
      "lod3_tris": 1500,
      "tex_max": 2048,
      "mat_slots": 4
    },
    "kit_piece": {
      "lod0_tris": 5000,
      "lod3_tris": 500,
      "tex_max": 1024,
      "mat_slots": 2
    },
    "decal": {
      "lod0_tris": 200,
      "lod3_tris": null,
      "tex_max": 1024,
      "mat_slots": 1
    }
  },
  "lod_suffix_regex": "_LOD(?P<tier>[0-3])$",
  "detection_rules": [
    {
      "class": "hero_char",
      "regex": "^SKM_AFL_.*Hero",
      "note": "Skeletal hero characters (player + enemies)."
    },
    {
      "class": "heavy_weapon",
      "regex": "^SM_AFL_.*Weapon",
      "note": "Heavy weapons (Mass Driver, Particle Lance, etc)."
    },
    {
      "class": "decal",
      "regex": "^SM_AFL_.*Decal",
      "note": "Surface decals (scorch, signage)."
    },
    {
      "class": "kit_piece",
      "regex": "^SM_AFL_.*Kit",
      "note": "Modular kit pieces."
    },
    {
      "class": "env_prop",
      "regex": "^SM_AFL_",
      "note": "Static environment props (fallback static-mesh rule, order matters)."
    }
  ],
  "naming_rules": {
    "hero_char": "^SKM_AFL_[A-Za-z0-9]+(_Hero[A-Za-z0-9]*)?(_LOD[0-3])?$",
    "heavy_weapon": "^SM_AFL_[A-Za-z0-9]+_Weapon[A-Za-z0-9]*(_LOD[0-3])?$",
    "env_prop": "^SM_AFL_[A-Za-z0-9_]+?(_LOD[0-3])?$",
    "kit_piece": "^SM_AFL_[A-Za-z0-9]+_Kit[A-Za-z0-9]*(_LOD[0-3])?$",
    "decal": "^SM_AFL_[A-Za-z0-9]+_Decal[A-Za-z0-9]*$"
  },
  "hero_sockets": [
    "head",
    "hand_l",
    "hand_r",
    "foot_l",
    "foot_r",
    "weapon_socket"
  ]
}
